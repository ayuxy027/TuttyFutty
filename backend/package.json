{
  "name": "tuttyfutty-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "NODE_ENV=test JWT_SECRET=dev-secret-key-change-in-production-12345678901234567890 vitest run",
